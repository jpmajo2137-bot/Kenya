# ===========================================
# Kenya Vocab App - Environment Variables
# ===========================================
# 이 파일을 복사해서 .env 파일로 만들고, 실제 값을 입력하세요.
# cp .env.example .env

# -------------------------------------------
# OpenAI API
# -------------------------------------------
# OpenAI API 키 (https://platform.openai.com/api-keys)
VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 사용할 모델 (기본: gpt-4o-mini)
VITE_OPENAI_MODEL=gpt-4o-mini

# -------------------------------------------
# Google Gemini API (AI 번역 사전)
# -------------------------------------------
# Gemini API 키 (https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------
# Microsoft Azure TTS (음성 합성)
# -------------------------------------------
# Azure Speech Services 구독 키
# https://portal.azure.com > Cognitive Services > Speech
VITE_AZURE_TTS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure 리전 (예: koreacentral, eastasia, westus, etc.)
VITE_AZURE_TTS_REGION=koreacentral

# (선택) 음성 설정 - 기본값 사용 시 생략 가능
# 한국어 음성 (기본: ko-KR-SunHiNeural)
# VITE_AZURE_TTS_KO_VOICE=ko-KR-SunHiNeural

# 스와힐리어 음성 (기본: sw-KE-ZuriNeural)
# VITE_AZURE_TTS_SW_VOICE=sw-KE-ZuriNeural

# 영어 음성 (기본: en-US-JennyNeural)
# VITE_AZURE_TTS_EN_VOICE=en-US-JennyNeural

# 말하기 속도 (0.5 ~ 2.0, 기본: 0.9)
# VITE_AZURE_TTS_SPEED=0.9

# -------------------------------------------
# Supabase (Cloud Database)
# -------------------------------------------
# Supabase 프로젝트 URL (https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Supabase anon/public 키 (클라이언트용)
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (선택) Supabase service role 키 (서버용, 클라이언트에 노출 금지!)
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx





